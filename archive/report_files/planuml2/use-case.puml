@startuml UseCase_ByInes

left to right direction
title Diagramme de Cas d'Utilisation - E-Commerce byines

skinparam {
    BackgroundColor #FFFDF9
    Shadowing false
    RoundCorner 10
    ArrowColor #5B4F43
    BorderColor #5B4F43
    
    ActorBackgroundColor #D2C3B4
    ActorBorderColor #5B4F43
    ActorFontColor #1A1A1A
    
    UseCaseBackgroundColor #F6F4F0
    UseCaseBorderColor #8C7D6C
    UseCaseFontColor #1A1A1A
    
    PackageBackgroundColor #FFFDF9
    PackageBorderColor #D2C3B4
}

actor "Client" as C
actor "Administrateur" as A
actor "Système WhatsApp" as S

package "Vitrine & Espace Client" {
    usecase "Consulter le catalogue" as UC1
    usecase "Filtrer par catégorie" as UC2
    usecase "Ajouter à la wishlist" as UC_W
    usecase "Ajouter au panier" as UC3
    usecase "Passer commande" as UC4
    usecase "Gérer son profil et adresses" as UC5
    usecase "Laisser un avis" as UC_R
}

package "Espace Administration" {
    usecase "S'authentifier" as UC6
    usecase "Gérer les produits et images" as UC7
    usecase "Gérer les collections" as UC_C
    usecase "Suivre les commandes" as UC8
    usecase "Modifier les stocks (variantes)" as UC9
}

package "Services Tiers" {
    usecase "Envoi message confirmation" as UC10
}

C --> UC1
C --> UC2
C --> UC_W
C --> UC3
C --> UC4
C --> UC5
C --> UC_R

A --> UC6
A --> UC7
A --> UC_C
A --> UC8
A --> UC9

UC4 ..> UC10 : <<include>>
S --> UC10

@enduml
