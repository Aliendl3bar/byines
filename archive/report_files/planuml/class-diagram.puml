@startuml ClassDiagram_Simple

title Diagramme de Classes — Cabinet Médical

' === STYLE ===
skinparam {
    BackgroundColor white
    RoundCorner 10
    ArrowColor #2C3E50
    ClassBackgroundColor #EBF5FB
    ClassBorderColor #2980B9
    ClassHeaderBackgroundColor #2980B9
    ClassFontColor #2C3E50
    ClassStereotypeFontColor white
    PackageBackgroundColor #F8F9F9
    PackageBorderColor #BDC3C7
}

' =====================================================
' CLASSES REELLES SEULEMENT
' =====================================================

class DatabaseConnection {
    - hostName : string
    - databaseName : string
    - userName : string
    - userPassword : string
    - databaseConnection : PDO
    --
    + getConnection() : PDO
}

class Appointment {
    - databaseConnection : PDO
    - tableName : string
    --
    + id : int
    + name : string
    + email : string
    + phone : string
    + cni : string
    + service_type : string
    + service_id : int
    + appointment_date : date
    + time_slot_id : int
    + message : string
    + medical_document : string
    + reference_number : string
    + public_token : string
    + status : string
    + created_at : datetime
    + service_name : string
    --
    + __construct(PDO $database)
    + createAppointment() : bool
    + fetchAllAppointments() : array
    + fetchAppointmentById() : bool
    + updateAppointmentStatus() : bool
    + updateAppointment() : bool
    + deleteAppointment() : bool
    + getDashboardStatistics() : array
}

' =====================================================
' PAGES QUI UTILISENT CES CLASSES
' =====================================================

package "Pages Front" as FrontPkg #D5F5E3 {
    class "index.php" as Index <<page>>
    class "confirmation.php" as Confirm <<page>>
    class "pending-confirmation.php" as Pending <<page>>
    class "track-appointment.php" as Track <<page>>
}

package "Pages Admin" as BackPkg #FDEDEC {
    class "admin/*.php" as Back <<groupe>>
}

package "API / Traitement" as ApiPkg #F5EEF8 {
    class "traitement/*.php" as API <<groupe>>
}

' =====================================================
' RELATIONS SIMPLES
' =====================================================

DatabaseConnection --> PDO : crée
Appointment --> PDO : utilise
FrontPkg --> DatabaseConnection : utilise
FrontPkg --> Appointment : lit (track, confirm, pending)
BackPkg --> DatabaseConnection : utilise
BackPkg --> Appointment : modifie (status)
ApiPkg --> DatabaseConnection : utilise
ApiPkg --> Appointment : crée

note bottom of Appointment
  Toutes les méthodes utilisent
  des Prepared Statements PDO.
  Pas de SQL injecté.
end note

legend bottom
  |= Symbole |= Sens |
  | --> | Dépendance / Utilise |
  | PDO | Classe native PHP |
  | Appointment | Modèle CRUD |
  | DatabaseConnection | Connexion unique |
end legend

@enduml
